# MFEPS バックエンド coverage 設定（Phase 9: CI pytest-cov ゲート 75%）
# WebUI / エントリポイントは別途 E2E 対象。バックエンド品質ゲート用に集計から除外。
[run]
source = src
omit =
    src/ui/*
    src/main.py
    # 光学オプション: ネイティブ DLL / 実ドライブ依存が強く CI では未実行
    src/core/aacs_reader.py
    src/core/dvdcss_reader.py

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
