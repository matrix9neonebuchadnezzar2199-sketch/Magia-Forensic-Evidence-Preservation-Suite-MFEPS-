# MFEPS v2.0 設定ファイル
# このファイルを .env にコピーして使用してください

# サーバー設定
MFEPS_PORT=8580
# WebUI バインド（127.0.0.1 で同一マシンのみ。LAN から開放する場合は 0.0.0.0 等）
BIND_ADDRESS=127.0.0.1
# ログインセッション有効期限（時間、1〜168）
SESSION_TIMEOUT_HOURS=8

# 出力先
MFEPS_OUTPUT_DIR=./output

# イメージング設定
MFEPS_BUFFER_SIZE=1048576

# テーマ
MFEPS_THEME=dark
MFEPS_FONT_SIZE=16

# RFC3161 タイムスタンプ
MFEPS_RFC3161_ENABLED=false
MFEPS_RFC3161_TSA_URL=http://timestamp.digicert.com

# 光学メディア二回読取
MFEPS_DOUBLE_READ_OPTICAL=false

# ログレベル
MFEPS_LOG_LEVEL=INFO

# DLL パス（参考。PyPI pydvdcss はこの変数を読まず ctypes で libdvdcss を解決）
DVDCSS_LIBRARY=./libs/libdvdcss-2.dll
# libdvdcss 本体が読む環境変数（起動前に有効である必要あり。main が .env から os.environ に反映）
# 0=オフ 1=警告 2=詳細 — DVD 診断時に有効化
# DVDCSS_VERBOSE=2
# 復号方式（例: title）。空のままなら libdvdcss 既定
# DVDCSS_METHOD=

# AACS (Blu-ray) 復号
AACS_LIBRARY=./libs/libaacs.dll
AACS_KEYDB_PATH=
# MakeMKV（将来用）
MAKEMKVCON_PATH=

# E01 (ewfacquire / libewf)
# 未設定でもプロジェクト直下の libs/ewfacquire.exe（または libs/ewftools-x64/ewfacquire.exe）が
# 存在すれば自動で利用されます。上書きする場合のみ以下を設定してください。
# 詳細・接続テスト・デフォルト取得パラメータは WebUI の「設定 → E01 出力」でも指定可能
# 例: libs 直下
# EWFACQUIRE_PATH=./libs/ewfacquire.exe
# EWFVERIFY_PATH=./libs/ewfverify.exe
# 例: libewf を libs/ewftools-x64/ に配置した場合（config デフォルトは ./libs/ewfacquire.exe なのでパスを合わせる）
# EWFACQUIRE_PATH=./libs/ewftools-x64/ewfacquire.exe
# EWFVERIFY_PATH=./libs/ewftools-x64/ewfverify.exe
# EWFINFO_PATH=./libs/ewfinfo.exe
# E01_SEGMENT_SIZE_BYTES=1500000000
# E01_COMPRESSION_METHOD=deflate
# E01_COMPRESSION_LEVEL=fast
# E01_EWF_FORMAT=encase6
