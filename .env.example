# MFEPS v2.0 設定ファイル
# このファイルを .env にコピーして使用してください

# サーバー設定
MFEPS_PORT=8580

# 出力先
MFEPS_OUTPUT_DIR=./output

# イメージング設定
MFEPS_BUFFER_SIZE=1048576

# テーマ
MFEPS_THEME=dark
MFEPS_FONT_SIZE=16

# RFC3161 タイムスタンプ
MFEPS_RFC3161_ENABLED=false
MFEPS_RFC3161_TSA_URL=http://timestamp.digicert.com

# 光学メディア二回読取
MFEPS_DOUBLE_READ_OPTICAL=false

# ログレベル
MFEPS_LOG_LEVEL=INFO

# DLL パス
DVDCSS_LIBRARY=./libs/libdvdcss-2.dll
